/**
 * @file all_tests.cpp
 * @brief 主测试入口 - 自动生成文件
 */

#include "test_common.h"
#include <iostream>
#include <cstring>
#include <sstream>

// 包含所有算子的测试头文件
@TEST_INCLUDES@

static std::string normalize_name(const char* s) {
    std::string result;
    for (const char* p = s; *p; ++p) {
        char c = std::tolower(static_cast<unsigned char>(*p));
        if (c != '_' && c != '-') result += c;
    }
    return result;
}

static bool should_run_test(const char* name) {
    const char* filter_env = std::getenv("OPS_FFT_TEST_FILTER");
    if (!filter_env || std::strlen(filter_env) == 0) {
        return true;
    }
    std::string name_norm = normalize_name(name);
    std::stringstream ss(filter_env);
    std::string token;
    while (std::getline(ss, token, ',')) {
        std::string token_norm = normalize_name(token.c_str());
        if (name_norm == token_norm || name_norm.find(token_norm) == 0) {
            return true;
        }
    }
    return false;
}

int main() {
    setenv("PYTHONDONTWRITEBYTECODE", "1", 0);

    std::cout << "========================================" << std::endl;
    std::cout << "       ops-fft 算子测试套件" << std::endl;
    std::cout << "========================================" << std::endl;
    std::cout << std::endl;

    // 初始化 ACL
    aclrtStream stream = nullptr;
    int ret = OpsFftTest::ACLManager::init(stream);
    if (ret != 0) {
        std::cerr << "Failed to initialize ACL" << std::endl;
        return 1;
    }

    // 运行所有测试
    auto& tests = OpsFftTest::TestRegistry::get_tests();
    for (const auto& test_entry : tests) {
        if (!should_run_test(test_entry.name)) {
            std::cout << "[SKIP] " << test_entry.name << std::endl;
            continue;
        }
        OpsFftTest::TestStats local_stats;
        TEST_PRINT_HEADER(test_entry.name);
        test_entry.func(stream, local_stats);
        TEST_PRINT_RESULT(test_entry.name, local_stats);
        std::cout << std::endl;
    }

    // 打印全局结果
    TEST_PRINT_GLOBAL_RESULT();

    // 打印失败用例列表
    TEST_PRINT_FAILED_CASES();

    // 清理残留 bin 文件
    const char* data_root = std::getenv("OPS_FFT_TEST_DATA_ROOT");
    if (data_root && std::strlen(data_root) > 0) {
        std::string cleanup_cmd = std::string("find ") + data_root + " -name '*.bin' -delete 2>/dev/null";
        system(cleanup_cmd.c_str());
    }

    // 清理 ACL
    OpsFftTest::ACLManager::finalize(stream);

    return (OpsFftTest::g_global_stats.failed == 0) ? 0 : 1;
}
