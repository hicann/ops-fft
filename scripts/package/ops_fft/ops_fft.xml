<?xml version="1.0" encoding="UTF-8"?>
<config name="ops_fft" copy_type="delivery" src_path="lib/" dst_path="ops_fft" install_type="all" install_mod="550" install_own="$username:$usergroup">
    <package_info>
        <product_name>cann</product_name>
        <chip_name>950</chip_name>
        <func_name>ops-fft</func_name>
        <suffix>run</suffix>
        <install_script>share/info/ops_fft/script/install.sh</install_script>
        <help>share/info/ops_fft/script/help.info</help>
        <cleanup>share/info/ops_fft/script/cleanup.sh</cleanup>
    </package_info>
    <generate_info value="ops_fft_version.h" dst_path="share/info/ops_fft" install_path="$(TARGET_ENV)/include/version" install_mod="440" install_type="devel" generator="version_header">
       <OPS_FFT_VERSION>$(ASCEND_VER)</OPS_FFT_VERSION>
       <OPS_FFT_TIMESTAMP>$(TIMESTAMP_NO)</OPS_FFT_TIMESTAMP>
    </generate_info>
    <generate_info value="scene.info" dst_path="share/info/ops_fft" install_path="share/info/ops_fft" install_mod="440">
        <os>$(OS_NAME)</os>
        <os_version>$(OS_VER)</os_version>
        <arch>$(ARCH)</arch>
    </generate_info>
    <file_info value="ops_fft_script" copy_type="source" src_path="" dst_path="share/info/ops_fft" install_path="share/info/ops_fft">
        <file value="script" entity="true"/>
        <file value="version.info"/>
    </file_info>
    <block_info dependtree="false" dst_path="ops_fft" block_conf_path="ascend">
        <block name="EngineeringCommon"/>
        <block name="EngineeringFiles"/>
        <block name="OpsFft"/>
        <block name="OpsFftInc"/>
    </block_info>
    <dir_info value="ops_fft" install_path="ops_fft" install_type="all">
        <path value="share" install_mod="750"/>
        <path value="share/info" install_mod="750"/>
        <path value="share/info/ops_fft" install_mod="550"/>
        <path value="share/info/ops_fft/script" install_mod="550"/>
    </dir_info>
</config>